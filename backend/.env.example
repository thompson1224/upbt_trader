# Application
APP_ENV=local
APP_NAME=upbit-ai-trader
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg://trader:trader_secret@localhost:5432/upbit_trader

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT + 관리자 인증
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ALG=HS256
JWT_EXPIRE_MIN=1440
# 관리자 비밀번호 (미설정 시 JWT_SECRET 값을 사용)
# staging/prod에서는 반드시 강력한 비밀번호로 설정할 것
ADMIN_PASSWORD=

# Upbit API (암호화되어 DB에 저장 - 환경변수는 마스터 키용)
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# Claude API
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Risk Management
RISK_MAX_DAILY_LOSS_PCT=0.03
RISK_MAX_POSITION_PCT=0.10
RISK_MAX_SINGLE_TRADE_PCT=0.01

# WebSocket
WS_RECONNECT_MIN_SEC=1
WS_RECONNECT_MAX_SEC=30
WS_PING_INTERVAL_SEC=60

# Backtesting
BACKTEST_DEFAULT_FEE_BPS=5
BACKTEST_DEFAULT_SLIPPAGE_BPS=3

# Encryption (API 키 암호화용 마스터 키)
ENCRYPTION_KEY=change-me-fernet-key-32-bytes-base64
